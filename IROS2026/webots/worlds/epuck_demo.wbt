}

# Start marker (blue)
DEF START_MARKER Solid {
  translation -0.7 -0.7 0.01
  rotation 1 0 0 1.5708
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.2 0.2 0.8
        metalness 0
        roughness 0.5
        emissiveColor 0.1 0.1 0.4
      }
      geometry Cylinder {
        radius 0.05
        height 0.02
      }
    }
