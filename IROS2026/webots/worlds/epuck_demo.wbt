  }
}

# Goal marker (green)
DEF GOAL Solid {
  translation 0.5 0.5 0.01
  rotation 1 0 0 1.5708
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.2 0.8 0.2
        metalness 0
        roughness 0.5
        emissiveColor 0.1 0.4 0.1
      }
      geometry Cylinder {
        radius 0.05
        height 0.02
      }
    }
