\@writefile{lot}{\contentsline {table}{\numberline {3{}-2}{\ignorespaces Safety-Gymnasium 在不同任务和惩罚系数设置下的结果。单智能体（上）：Goal、Circle、Push，且 $r_{col} \in {1.0, 0.5, 0.1}$。多智能体（下）：Multi-Goal。红色加粗表示最优奖励，绿色字体表示最低代价。基线方法报告均值；PPO\_CM 报告 3 个随机种子下的均值$\pm $标准差。训练步数为 $10^5$。 \relax }}{23}{table.caption.8}\protected@file@percent }
\newlabel{tab:main_results}{{3{}-2}{23}{Safety-Gymnasium 在不同任务和惩罚系数设置下的结果。单智能体（上）：Goal、Circle、Push，且 $r_{col} \in {1.0, 0.5, 0.1}$。多智能体（下）：Multi-Goal。红色加粗表示最优奖励，绿色字体表示最低代价。基线方法报告均值；PPO\_CM 报告 3 个随机种子下的均值$\pm $标准差。训练步数为 $10^5$。 \relax }{table.caption.8}{}}
